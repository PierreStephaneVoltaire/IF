# IF Prototype A1 - Environment Variables
# Copy this file to .env and fill in your values

# Required: OpenRouter API Key
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
IF_CORE_TABLE_NAME=if-core
IF_HEALTH_TABLE_NAME=if-health
# Optional: Number of recent messages to send to routing models and presets
# Default: 8
MESSAGE_WINDOW=8

# Optional: Crisis score threshold for mental health routing override
# Low default (0.3) because false negatives are catastrophic
# Default: 0.3
CRISIS_THRESHOLD=0.3

# Optional: Minimum top score for confident routing decision
# Default: 0.6
CONFIDENCE_THRESHOLD=0.6

# Optional: Minimum gap between top and second score for confident decision
# Default: 0.2
CONFIDENCE_GAP=0.2

# Optional: Model for OpenWebUI suggestion/title generation
# Default: mistralai/mistral-nemo
SUGGESTION_MODEL=mistralai/mistral-nemo

# Optional: Comma-separated list of models for parallel conversation scoring
# Must support structured output / JSON mode
# Default: minimax/minimax-m2,google/gemini-2.5-flash-lite,qwen/qwen3-32b,openai/gpt-oss-120b,z-ai/glm-4.7-flash
SCORING_MODELS=google/gemini-2.5-flash-lite,openai/gpt-oss-120b,anthropic/claude-haiku-4.5

# Optional: Slug of the mental health preset for crisis routing
# Default: mental-health-black-box
MENTAL_HEALTH_PRESET=general

# Optional: Local directory for file artifact generation
# Default: ./sandbox
SANDBOX_PATH=./sandbox

# Optional: Path to persistent memory store file
# Default: ./data/memory.json
MEMORY_DB_PATH=./data/memory.json

# Optional: Path for conversation persistence
# Default: ./data/conversations
PERSISTENCE_DIR=./data/conversations

# Optional: Storage backend for webhook records
# Options: sqlite (default), dynamodb (future)
# Default: sqlite
STORE_BACKEND=sqlite

# Optional: SQLite database file path for webhook storage
# Default: ./data/store.db
STORAGE_DB_PATH=./data/store.db

# Optional: Model for topic shift detection
# Should be a fast, cheap model that supports chat completions
# Default: z-ai/glm-4.7-flash
TOPIC_SHIFT_MODEL=z-ai/glm-4.7-flash

# Optional: Model for directive content rewriting
# Used when rewriting directive content via LLM
# Default: anthropic/claude-opus-4.6
DIRECTIVE_REWRITE_MODEL=anthropic/claude-opus-4.6

# Optional: Model for conversation condensation
# Used to summarize long conversations for context preservation
# Default: anthropic/claude-3-haiku
CONDENSER_MODEL=anthropic/claude-3-haiku

# Optional: Fallback model for heartbeat pondering
# Used when the pondering preset is not available
# Default: openai/gpt-4o-mini
HEARTBEAT_FALLBACK_MODEL=openai/gpt-4o-mini

# Optional: Fallback model for presets without defined models
# Used when a preset doesn't specify a model
# Default: anthropic/claude-3.5-sonnet
PRESET_FALLBACK_MODEL=anthropic/claude-3.5-sonnet

# Optional: Model for reflection engine and opinion formation
# Used for self-reflection, opinion formation, and meta-analysis
# Default: openrouter/@preset/general
REFLECTION_MODEL=openrouter/@preset/general

# Optional: Model for plan execution subagents
# Used by orchestrator for sequential task delegation
# Default: anthropic/claude-sonnet-4
ORCHESTRATOR_SUBAGENT_MODEL=anthropic/claude-sonnet-4

# Optional: Model for parallel analysis subagents
# Lighter weight model for faster code analysis
# Default: anthropic/claude-haiku-4.5
ORCHESTRATOR_ANALYSIS_MODEL=anthropic/claude-haiku-4.5

# Optional: Model for synthesis of parallel analysis results
# Used to combine multiple analysis perspectives
# Default: anthropic/claude-sonnet-4
ORCHESTRATOR_SYNTHESIS_MODEL=anthropic/claude-sonnet-4

# Optional: MCP Server API Keys
# Google Sheets credentials (base64 encoded JSON)
GOOGLE_SHEETS_CREDENTIALS=

# Alpha Vantage API key for stock data (get free key at https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=

# Optional: API server bind address
# Default: 0.0.0.0
HOST=0.0.0.0

# Optional: API server bind port
# Default: 8000
PORT=8000



# Optional: Inactivity window (seconds) before batched channel messages are dispatched
# Messages within this window are accumulated and sent together
# Default: 30
CHANNEL_DEBOUNCE_SECONDS=30

# Optional: Maximum characters per chunk for channel responses
# Discord has a 2000 char limit, 1500 provides safety margin
# Default: 1500
CHANNEL_MAX_CHUNK_CHARS=1500

# Optional: Polling interval (seconds) for OpenWebUI channel listener
# Default: 5.0
OPENWEBUI_POLL_INTERVAL=5.0



# Optional: Enable/disable heartbeat system for proactive engagement
# When enabled, the agent will initiate pondering conversations on idle channels
# Default: true
HEARTBEAT_ENABLED=true

# Optional: Hours of inactivity before a channel is considered idle
# After this period of no messages, the channel becomes eligible for heartbeat
# Default: 6.0
HEARTBEAT_IDLE_HOURS=6.0

# Optional: Hours to wait between heartbeat messages to the same channel
# Prevents spamming channels with repeated heartbeat messages
# Default: 6.0
HEARTBEAT_COOLDOWN_HOURS=6.0

# Optional: Time range when heartbeats should not be sent (UTC)
# Format: "HH:MM-HH:MM", spans midnight if start > end
# Set to empty string to disable quiet hours
# Default: 23:00-07:00
HEARTBEAT_QUIET_HOURS=23:00-07:00


# Optional: Docker image for Open Terminal containers
# Default: ghcr.io/open-webui/open-terminal:latest
TERMINAL_IMAGE=ghcr.io/open-webui/open-terminal:latest

# Optional: Docker network for terminal containers
# Default: if-terminal-net
TERMINAL_NETWORK=if-terminal-net

# Optional: Memory limit per terminal container
# Default: 512m
TERMINAL_MEM_LIMIT=512m

# Optional: CPU quota (100000 = 1 CPU, 50000 = 0.5 CPU)
# Default: 50000
TERMINAL_CPU_QUOTA=50000

# Optional: Seconds before idle containers are stopped
# Default: 3600 (1 hour)
TERMINAL_IDLE_TIMEOUT=3600

# Optional: Seconds to wait for container health check
# Default: 30.0
TERMINAL_STARTUP_TIMEOUT=30.0

# Optional: Maximum number of concurrent terminal containers
# Default: 20
TERMINAL_MAX_CONTAINERS=20

# Optional: Docker named volumes host root path (for file serving)
# On standard Docker installs this is /var/lib/docker/volumes/
# Set to empty string to disable direct host access
# Default: /var/lib/docker/volumes
TERMINAL_VOLUME_HOST_ROOT=/var/lib/docker/volumes


# =============================================================================
# Health Module Configuration
# =============================================================================

# Optional: DynamoDB table name for health program storage
# Used by ProgramStore for training program versioning
# Default: if-health-store
# Note: IF_HEALTH_TABLE_NAME is already defined above (line 8)
# HEALTH_TABLE_NAME=if-health-store

# Optional: Partition key value for health program storage
# Identifies the operator's program in DynamoDB
# Default: operator
HEALTH_PROGRAM_PK=operator

# Optional: Directory containing health PDF documents for RAG
# IPF rulebook, anti-doping list, supplement PDFs, etc.
# Default: docs/health
HEALTH_DOCS_DIR=docs/health

# Optional: Model for research agent spawned by health tools
# Used for deep research on training, nutrition, or competition topics
# Default: anthropic/claude-opus-4-5
RESEARCH_AGENT_MODEL=anthropic/claude-opus-4-5
