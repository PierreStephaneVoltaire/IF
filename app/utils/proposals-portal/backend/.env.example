# AWS Configuration (uses IAM role/instance profile - no hardcoded credentials)
AWS_REGION=ca-central-1

# DynamoDB Tables
IF_PROPOSALS_TABLE_NAME=if-proposals
IF_CORE_TABLE_NAME=if-core

# Operator Primary Key
IF_OPERATOR_PK=operator

# OpenRouter for Plan Generation
OPENROUTER_API_KEY=
PLAN_GENERATION_MODEL=@preset/heavy

# Server
PORT=3004
