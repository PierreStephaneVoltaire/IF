# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Agent API Configuration
# URL of the main agent FastAPI server (app/src/main.py)
AGENT_API_URL=http://localhost:8000
# Must match API_MODEL_NAME in app/src/config.py (default: if-prototype)
AGENT_MODEL_NAME=if-prototype

# Server Configuration
HOST=0.0.0.0
PORT=8080

# History Configuration
# Number of Discord messages to include in the context sent to the agent
DEFAULT_HISTORY_LIMIT=50
MAX_HISTORY_LIMIT=500

# Request timeout for agent API calls (seconds)
AGENT_TIMEOUT=120.0

# Response chunking (Discord has a 2000 char message limit)
MAX_CHUNK_CHARS=1500
INTER_CHUNK_DELAY=0.5

# Logging
LOG_LEVEL=INFO
